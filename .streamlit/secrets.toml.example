# Streamlit Community Cloud / local secrets for the RRG reader app.
# Copy to .streamlit/secrets.toml (gitignored). These are the PUBLIC read-only
# values — the anon key is publishable and RLS keeps it read-only — so the app
# also ships with them as defaults and runs with no secrets at all. Override
# here only if you point the app at a different Supabase project.
SUPABASE_URL = "https://mptecsecdhdoxqocubuv.supabase.co"
SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-key..."
