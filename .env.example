# ── Batch pipeline (GitHub Actions / local) ─────────────────────────────────
# Writes via Supabase REST using the service_role key (bypasses RLS).
# Dashboard -> Settings -> API. NEVER commit the real key.
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=[YOUR-SERVICE-ROLE-KEY]

# First-ever ingest backfills this many years of daily history (default 3).
BACKFILL_YEARS=3

# ── Streamlit app (Phase 4 — read-only client) ──────────────────────────────
# The app uses the REST endpoint + anon (publishable) key, never the service key.
SUPABASE_ANON_KEY=[YOUR-ANON-PUBLISHABLE-KEY]
