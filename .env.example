# ── Batch pipeline (GitHub Actions / local) ─────────────────────────────────
# Supabase Postgres connection string. Dashboard -> Project Settings ->
# Database -> Connection string (URI). Use the session/transaction pooler URI
# for CI. NEVER commit the real value.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# First-ever ingest backfills this many years of daily history (default 3).
BACKFILL_YEARS=3

# ── Streamlit app (Phase 4 — read-only client) ──────────────────────────────
# The app uses the REST endpoint + anon (publishable) key, not the DB password.
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=[YOUR-ANON-PUBLISHABLE-KEY]
